DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
DJANGO_ALLOWED_HOSTS=blog.example.com,localhost
DJANGO_CORS_ALLOWED_ORIGINS=https://blog.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://blog.example.com
DJANGO_LOG_LEVEL=INFO

DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false

DJANGO_MEDIA_ROOT=/var/www/shared/whiteraven-blog/media
DJANGO_STATIC_ROOT=/var/www/shared/whiteraven-blog/static
DJANGO_UPLOAD_TEMP_DIR=/var/www/tmp/whiteraven-blog/uploads
TMPDIR=/var/www/tmp/whiteraven-blog

DJANGO_DB_ENGINE=postgresql
DJANGO_DB_NAME=whiteraven_blog
DJANGO_DB_USER=whiteraven_blog
DJANGO_DB_PASSWORD=replace-with-a-strong-database-password
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432
DJANGO_DB_CONN_MAX_AGE=60

VITE_API_BASE_URL=/api
