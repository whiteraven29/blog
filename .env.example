# Django
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173
DJANGO_LOG_LEVEL=INFO
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0

DJANGO_DB_ENGINE=sqlite
# DJANGO_SQLITE_PATH=/absolute/path/to/db.sqlite3

# Optional seed account (used only by backend/seed_posts.py)
BLOG_ADMIN_USERNAME=admin
BLOG_ADMIN_PASSWORD=replace-with-a-strong-password
BLOG_ADMIN_EMAIL=admin@example.com

# Vite: leave empty for the same-origin /api proxy.
VITE_API_BASE_URL=/api
